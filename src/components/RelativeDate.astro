---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"time"> {
  date: Date;
}

const { date, ...props } = Astro.props as Props;
const epochDate = date.getTime();
const id = Math.random().toString(36);
---

<time id={`relative-time-${id}`} {...props}></time>

<script is:inline define:vars={{ epochDate, id }}>
  const date = new Date(epochDate);
  const now = new Date();
  const diffInSeconds = Math.floor((now.getTime() - date.getTime()) / 1000);
  const days = Math.floor(diffInSeconds / 86400);
  const timeElement = document.getElementById(`relative-time-${id}`);

  var dateString;

  if (days < 1) {
    dateString = "Today";
  } else if (days < 30) {
    dateString = `${days} day${days !== 1 ? "s" : ""} ago`;
  } else {
    dateString = new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(date);
  }

  timeElement.setAttribute("datetime", date.toISOString());
  timeElement.textContent = dateString;
</script>
