---
export interface Props {
  checked?: boolean;
  class?: string;
  children: any;
}
const { checked, class: className, ...props } = Astro.props;
---

<span class:list={["flex my-4 leading-8", className]}>
  <span
    class:list={[
      "inline-block relative size-5 top-1 mr-2 border-2 rounded-md pl-0.5 pt-0.5",
      checked
        ? "bg-primary border-primary text-background-light dark:text-background-dark"
        : "border-foreground-light dark:border-foreground-dark",
    ]}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class:list={["h-3.5 w-3.5 block", checked ? "" : "hidden"]}
      viewBox="0 0 20 20"
      fill="currentColor"
      stroke="currentColor"
      stroke-width="2"
    >
      <path
        fill-rule="evenodd"
        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
        clip-rule="evenodd"></path>
    </svg>
  </span>
  <div class="pl-3.5"><slot /></div>
</span>
